# Database
ZORCH_DATABASE_URL=postgres://user:password@localhost:5432/zorch
ZORCH_CLICKHOUSE_URL=http://localhost:8123

# Cache
ZORCH_REDIS_URL=redis://localhost:6379

# Application
ZORCH_APP_PORT=8080
ZORCH_RUST_LOG=info
ZORCH_TIMEOUT_SECS=60

# Circuit breaker: how long (in seconds) a failed backend is excluded from routing
# before it is allowed probe requests again. Default 30.
ZORCH_CIRCUIT_BREAKER_TIMEOUT_SECS=30

# Security
ZORCH_ENCRYPTION_KEY=your-secret-key-here
ZORCH_ADMIN_SECRET=your-admin-secret-here

# Inspector capture level: none | metadata_only | full
ZORCH_INSPECTOR_CAPTURE_LEVEL=metadata_only

# Default organization ID (used when creating API keys without explicit org)
ZORCH_DEFAULT_ORG_ID=

# Sticky routing: how long (in seconds) a client API key -> target API key mapping is cached.
# Default 300 (5 minutes).
ZORCH_STICKY_TARGET_KEY_TTL_SECS=300

# Fallback provider keys when no DB providers are configured
ZORCH_OPENAI_API_KEY=
ZORCH_ANTHROPIC_API_KEY=

# Comma-separated list of origins allowed by CORS for the admin API.
# Leave empty in local dev to allow any origin (a startup warning is logged).
# In production, set this to the exact origin(s) of your admin dashboard,
# for example: https://admin.example.com
ZORCH_CORS_ALLOWED_ORIGINS=
